# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=gemma2-9b-it

# Qdrant Configuration
# For Docker Compose, use http://qdrant:6333
# For local development, use http://localhost:6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_collection

# PostgreSQL Configuration
# For Docker Compose, use postgres as host
# For local development, use localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragchatbot

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/rag_chatbot.log

# Optional: Jupyter Configuration for development
JUPYTER_TOKEN=your_secure_token_here